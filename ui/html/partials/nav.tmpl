{{define "nav"}}
<nav class='site-nav'>
    <div class='site-nav__inner'>
        <div class='site-nav__group'>
            <a href='/'>Index</a>
            {{if .IsAuthenticated}}
                <a href='/snippet/create'>New note</a>
            {{end}}
            <a href='/about'>Notebook</a>
        </div>
        <div class='site-nav__group site-nav__group--end'>
            <button type='button' class='theme-toggle' data-theme-toggle aria-label='Toggle dark theme' aria-pressed='{{if eq .Theme "dark"}}true{{else}}false{{end}}'>{{if eq .Theme "dark"}}Light mode{{else}}Dark mode{{end}}</button>
        {{if .IsAuthenticated}}
            <a href='/account/view'>Account</a>
            <form action='/user/logout' method='POST'>
                <input type='hidden' name='csrf_token' value='{{.CSRFToken}}'>
                <button class='nav-button'>Logout</button>
            </form>
        {{else}}
            <a href='/user/signup'>Signup</a>
            <a href='/user/login'>Login</a>
        {{end}}
        </div>
    </div>
</nav>
{{end}}
