{{define "nav"}}
<nav>
    <div>
        <a href='/'>Home</a>

         {{if .IsAuthenticated}}
            <a href='/snippet/create'>Create snippet</a>
        {{end}}
        <a href='/about'>About</a>
    </div>
    <div>
        <button type='button' class='theme-toggle' data-theme-toggle aria-label='Toggle dark theme' aria-pressed='{{if eq .Theme "dark"}}true{{else}}false{{end}}'>{{if eq .Theme "dark"}}Light mode{{else}}Dark mode{{end}}</button>
        {{if .IsAuthenticated}}
            <a href='/account/view'>Account</a>
            <form action='/user/logout' method='POST'>
                <!-- Include the CSRF token -->
                <input type='hidden' name='csrf_token' value='{{.CSRFToken}}'>
                <button>Logout</button>
            </form>
        {{else}}
            <a href='/user/signup'>Signup</a>
            <a href='/user/login'>Login</a>

        {{end}}
    </div>
</nav>
{{end}}
