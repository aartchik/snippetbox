{{define "title"}}Change Password{{end}}

{{define "main"}}
<section class='form-shell form-shell--narrow'>
    <div class='form-shell__intro'>
        <p class='eyebrow'>Account security</p>
        <h2>Rotate your password.</h2>
        <p class='lede'>Confirm the current secret, then write a stronger replacement and keep the notebook locked down.</p>
    </div>
    <form action='/password/update' method='POST' class='panel form-panel'>
        <input type='hidden' name='csrf_token' value='{{.CSRFToken}}'>
        <div>
            <label>Current password</label>
            {{with .Form.FieldErrors.curr_password}}
                <label class='error'>{{.}}</label>
            {{end}}
            <input type='password' name='curr_password' value=''>
        </div>
        <div>
            <label>New password</label>
            {{with .Form.FieldErrors.new_password}}
                <label class='error'>{{.}}</label>
            {{end}}
            <input type='password' name='new_password' value='{{.Form.NewPassword}}'>
        </div>
        <div>
            <label>Confirm new password</label>
            {{with .Form.FieldErrors.confirm_password}}
                <label class='error'>{{.}}</label>
            {{end}}
            <input type='password' name='confirm_password' value='{{.Form.ConfirmNewPassword}}'>
        </div>
        <div>
            <input type='submit' value='Change password'>
        </div>
    </form>
</section>
{{end}}
