{{define "title"}}Home{{end}}

{{define "main"}}
    <h2>Latest Snippets</h2>
    {{if .IsAuthenticated}}
    {{if .Snippets}}
    <div class="searchbar">
<form class="searchbar__form" action="/search" method="GET">
    <button type="submit" class="searchbar__icon-btn">
        <img class="searchbar__icon" src="/static/img/open1.png" alt="search">
    </button>

    <input
      class="searchbar__input"
      type="search"
      name="q"
      placeholder="Search snippets"
      autocomplete="off"
    />
</form>

    </div>
{{end}}
    
        {{if .Snippets}}
        <table>
            <tr>
                <th>Title</th>
                <th>Created</th>
                <th>ID</th>
            </tr>
            {{range .Snippets}}
            <tr>
                <td><a href='/snippet/view/{{.ID}}'>{{.Title}}</a></td>
                <td>{{humanDate .Created}}</td>
                <td>#{{.ID}}</td>
            </tr>
            {{end}}
        </table>
        {{else}}
            <p>There's nothing to see here... yet!</p>
        {{end}}
    {{else}}
        <p><a href='/user/signup'>Signup</a> or <a href='/user/login'>login</a> to create your first snippet!</p>
    {{end}}
{{end}}