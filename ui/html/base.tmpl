{{define "base"}}
<!doctype html>
<html lang='en' data-theme='{{.Theme}}'>
    <head>
        <meta charset='utf-8'>
        <meta name='viewport' content='width=device-width, initial-scale=1'>
        <title>{{template "title" .}} - Snippetbox</title>
        <link rel='stylesheet' href='/static/css/main.css'>
        <link rel='shortcut icon' href='/static/img/favicon.ico' type='image/x-icon'>
        <link rel='preconnect' href='https://fonts.googleapis.com'>
        <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin>
        <link rel='stylesheet' href='https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;700&family=Fraunces:opsz,wght@9..144,600;9..144,700&display=swap'>
    </head>
    <body>
        <div class='page-shell'>
            <div class='page-glow page-glow--left'></div>
            <div class='page-glow page-glow--right'></div>
            <header class='site-header'>
                <div class='site-header__inner'>
                    <div class='site-brand'>
                        <p class='site-brand__eyebrow'>Developer notebook</p>
                        <h1><a href='/'>Snippetbox</a></h1>
                        <p class='site-brand__summary'>A calm place for code fragments, notes, and reusable ideas.</p>
                    </div>
                    <div class='site-header__stamp'>
                        <span class='site-header__stamp-label'>Session</span>
                        <strong>{{.CurrentYear}}</strong>
                    </div>
                </div>
            </header>
            {{template "nav" .}}
            <main class='site-main'>
                {{with .Flash}}
                    <div class='flash'>{{.}}</div>
                {{end}}
                {{template "main" .}}
            </main>
            <footer class='site-footer'>
                <p>Powered by <a href='https://golang.org/'>Go</a>.</p>
            </footer>
        </div>
        <script src="/static/js/main.js" type="text/javascript"></script>
    </body>
</html>
{{end}}
